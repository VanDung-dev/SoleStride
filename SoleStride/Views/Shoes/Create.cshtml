@model SoleStride.Models.Shoes
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Create Product";
}

<div class="page-header">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16" style="color:#6c757d;">
        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
    </svg>
    <h1>Create Product</h1>
</div>
<p class="page-subtitle">Fill in the details below to add a new shoe product to your catalogue.</p>

<div class="form-card">
    <form asp-action="Create" enctype="multipart/form-data" id="createForm">
        <div asp-validation-summary="ModelOnly" class="text-danger-custom"></div>

        <div class="form-section">
            <div class="form-section-title">Basic Information</div>
            <div class="mb-3">
                <label asp-for="ShoesName" class="form-label-custom"></label>
                <input asp-for="ShoesName" class="form-control form-control-custom" placeholder="e.g. Air Max Runner" />
                <span asp-validation-for="ShoesName" class="text-danger-custom"></span>
            </div>
            <div class="form-row">
                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label-custom"></label>
                    <select asp-for="CategoryId" class="form-control form-control-custom" asp-items="new SelectList(ViewBag.Categories ?? new List<Category>(), nameof(Category.CategoryId), nameof(Category.CategoryName))">
                        <option value="">Select a category</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger-custom"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ShoesGender" class="form-label-custom"></label>
                    <select asp-for="ShoesGender" class="form-control form-control-custom">
                        <option value="Men">Men</option>
                        <option value="Women">Women</option>
                        <option value="Unisex" selected>Unisex</option>
                    </select>
                    <span asp-validation-for="ShoesGender" class="text-danger-custom"></span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">Product Details</div>
            <div class="form-row">
                <div class="mb-3">
                    <label asp-for="ShoesSize" class="form-label-custom"></label>
                    <input asp-for="ShoesSize" class="form-control form-control-custom" placeholder="e.g. 10" />
                    <span asp-validation-for="ShoesSize" class="text-danger-custom"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ShoesColor" class="form-label-custom"></label>
                    <input asp-for="ShoesColor" class="form-control form-control-custom" placeholder="e.g. Black" />
                    <span asp-validation-for="ShoesColor" class="text-danger-custom"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Material" class="form-label-custom"></label>
                <input asp-for="Material" class="form-control form-control-custom" placeholder="e.g. Leather, Mesh" />
                <span asp-validation-for="Material" class="text-danger-custom"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label-custom"></label>
                <textarea asp-for="Description" class="form-control form-control-custom" rows="3" placeholder="Brief product description..."></textarea>
                <span asp-validation-for="Description" class="text-danger-custom"></span>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">Pricing</div>
            <div class="form-row">
                <div class="mb-3">
                    <label asp-for="Price" class="form-label-custom"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="border-radius:10px 0 0 10px; border:1px solid #e9ecef; background:#f8f9fa;">$</span>
                        <input asp-for="Price" class="form-control form-control-custom" style="border-radius:0 10px 10px 0;" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Price" class="text-danger-custom"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="SalePercentage" class="form-label-custom"></label>
                    <div class="input-group">
                        <input asp-for="SalePercentage" class="form-control form-control-custom" placeholder="0" />
                        <span class="input-group-text" style="border-radius:0 10px 10px 0; border:1px solid #e9ecef; background:#f8f9fa;">%</span>
                    </div>
                    <span asp-validation-for="SalePercentage" class="text-danger-custom"></span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">Product Image</div>
            <div class="image-upload-area" id="uploadArea">
                <input type="file" name="ImageFile" accept="image/*" id="imageInput" onchange="previewImage(event)" />
                <div class="image-upload-placeholder" id="uploadPlaceholder">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/>
                        <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-2-2-2.5 3-1-1.5-4 5h12z"/>
                    </svg>
                    <p class="image-upload-text"><strong>Click to upload</strong> or drag and drop</p>
                    <p class="image-upload-text" style="font-size:0.8rem; color:#adb5bd;">PNG, JPG, GIF up to 5MB</p>
                </div>
                <img id="imagePreview" class="image-preview" style="display:none;" alt="Preview" />
            </div>
        </div>

        <div class="d-flex gap-2 mt-4 pt-3" style="border-top:1px solid #f1f3f5;">
            <button type="submit" class="btn btn-submit">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-lg me-1" viewBox="0 0 16 16">
                    <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425a.247.247 0 0 1 .02-.022Z"/>
                </svg>
                Create Product
            </button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-back">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
                </svg>
                Back to Catalog
            </a>
        </div>
    </form>
</div>

<script>
function previewImage(event) {
    var file = event.target.files[0];
    if (file) {
        var reader = new FileReader();
        reader.onload = function(e) {
            var img = document.getElementById('imagePreview');
            img.src = e.target.result;
            img.style.display = 'block';
            document.getElementById('uploadPlaceholder').style.display = 'none';
        };
        reader.readAsDataURL(file);
    }
}

document.getElementById('uploadArea').addEventListener('dragover', function(e) {
    e.preventDefault();
    this.style.borderColor = '#212529';
    this.style.backgroundColor = '#fff';
});

document.getElementById('uploadArea').addEventListener('dragleave', function(e) {
    e.preventDefault();
    this.style.borderColor = '#dee2e6';
    this.style.backgroundColor = '#f8f9fa';
});

document.getElementById('uploadArea').addEventListener('drop', function(e) {
    e.preventDefault();
    this.style.borderColor = '#dee2e6';
    this.style.backgroundColor = '#f8f9fa';
    var files = e.dataTransfer.files;
    if (files.length > 0) {
        document.getElementById('imageInput').files = files;
        var event = new Event('change');
        document.getElementById('imageInput').dispatchEvent(event);
    }
});
</script>
